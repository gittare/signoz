{
  "id": "elasticsearch",
  "title": "Elasticsearch",
  "description": "Monitor Elasticsearch with metrics and logs",
  "author": {
    "name": "SigNoz",
    "email": "integrations@signoz.io",
    "homepage": "https://signoz.io"
  },
  "icon": "file://icon.svg",
  "categories": [
    "Database"
  ],
  "overview": "file://overview.md",
  "configuration": [
    {
      "title": "Prerequisites",
      "instructions": "file://config/prerequisites.md"
    },
    {
      "title": "Collect Metrics",
      "instructions": "file://config/collect-metrics.md"
    },
    {
      "title": "Collect Logs",
      "instructions": "file://config/collect-logs.md"
    }
  ],
  "assets": {
    "logs": {
      "pipelines": []
    },
    "dashboards": [
      "file://assets/dashboards/overview.json"
    ],
    "alerts": []
  },
  "connection_tests": {
    "logs": {
      "attribute_key": "source",
      "attribute_value": "elasticsearch"
    }
  },
  "data_collected": {
    "logs": [
      {
        "name": "Process ID",
        "path": "attributes.pid",
        "type": "string"
      },
      {
        "name": "Timestamp",
        "path": "timestamp",
        "type": "timestamp"
      },
      {
        "name": "Severity Text",
        "path": "severity_text",
        "type": "string"
      },
      {
        "name": "Severity Number",
        "path": "severity_number",
        "type": "number"
      }
    ],
    "metrics": [
      {
        "name": "elasticsearch.node.fs.disk.total",
        "type": "Gauge",
        "unit": "Bytes",
        "description": "Total disk space of the node"
      },
      {
        "name": "elasticsearch.node.fs.disk.free",
        "type": "Gauge",
        "unit": "Bytes",
        "description": "Free disk space of the node"
      },
      {
        "name": "elasticsearch.node.fs.disk.available",
        "type": "Gauge",
        "unit": "Bytes",
        "description": "Available disk space of the node"
      },
      {
        "name": "elasticsearch.os.cpu.usage",
        "type": "Gauge",
        "unit": "percent",
        "description": "CPU usage of the node"
      },
      {
        "name": "jvm.memory.heap.used",
        "type": "Gauge",
        "unit": "Bytes",
        "description": "Used heap memory of the JVM"
      },
      {
        "name": "jvm.memory.heap.max",
        "type": "Gauge",
        "unit": "Bytes",
        "description": "Max heap memory of the JVM"
      },
      {
        "name": "elasticsearch.cluster.health",
        "type": "Gauge",
        "unit": "number",
        "description": "Health status of the Elasticsearch cluster"
      },
      {
        "name": "elasticsearch.cluster.shards.active",
        "type": "Gauge",
        "unit": "number",
        "description": "Number of active shards in the cluster"
      },
      {
        "name": "elasticsearch.cluster.shards.unassigned",
        "type": "Gauge",
        "unit": "number",
        "description": "Number of unassigned shards in the cluster"
      },
      {
        "name": "elasticsearch.cluster.pending_tasks",
        "type": "Gauge",
        "unit": "number",
        "description": "Number of pending tasks in the cluster"
      },
      {
        "name": "elasticsearch.index.documents",
        "type": "Gauge",
        "unit": "number",
        "description": "Total document count across all indices"
      },
      {
        "name": "elasticsearch.index.shards.size",
        "type": "Gauge",
        "unit": "Bytes",
        "description": "Total disk usage of indices"
      },
      {
        "name": "elasticsearch.index.operations.search_count",
        "type": "Sum",
        "unit": "number",
        "description": "Total number of search queries on the index"
      },
      {
        "name": "elasticsearch.index.operations.search_time",
        "type": "Sum",
        "unit": "ms",
        "description": "Time spent on search queries"
      },
      {
        "name": "elasticsearch.node.operations.completed",
        "type": "Sum",
        "unit": "number",
        "description": "Rate of search requests"
      },
      {
        "name": "elasticsearch.node.operations.time",
        "type": "Sum",
        "unit": "ms",
        "description": "Latency of search queries"
      },
      {
        "name": "elasticsearch.node.cache.evictions",
        "type": "Sum",
        "unit": "number",
        "description": "Number of cache evictions"
      },
      {
        "name": "elasticsearch.node.cache.count",
        "type": "Gauge",
        "unit": "number",
        "description": "Number of cache entries"
      },
      {
        "name": "elasticsearch.node.cache.memory.usage",
        "type": "Gauge",
        "unit": "Bytes",
        "description": "Memory used by cache"
      }
    ]
  }
}
